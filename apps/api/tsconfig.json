{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node", // <--- IMPORTANTE: Ayuda a encontrar paquetes
    "paths": {
      "*": ["node_modules/*", "../../node_modules/*"] // <--- Busca también en la raíz
    }
  },
  "include": ["src/**/*.ts"]
}