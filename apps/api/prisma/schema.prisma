generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  name           String?
  emailVerified  Boolean        @default(false)
  image          String?
  categories     Category[]
  blockTypes     BlockType[]
  weeklyPlans    WeeklyPlan[]
  blockInstances BlockInstance[]
  sessions       Session[]
  accounts       Account[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

// Authentication tables owned by Better Auth (running in apps/web) but stored
// in this shared database. Model (PascalCase) and field names deliberately
// match Better Auth's expectations so it maps onto the existing User identity
// above — there is only one notion of "user". Prisma owns the migrations; the
// API reads Session here to authenticate requests (see auth guard).
model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  // Id of the dedicated "LifeTasker" Google calendar created once for this
  // connected account and remembered so completions don't re-create it. Owned
  // by the API's calendar sync (#35); Better Auth never reads this column.
  calendarId            String?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Category {
  id            String      @id @default(cuid())
  userId        String
  key           String
  name          String
  // Importance bonus applied to points earned in this category, as a percent
  // from 0 (baseline) to 100 (double). Read by scoring in a later slice.
  weightPercent Int         @default(0)
  // Hex color (#rrggbb) used by the overview grid and contribution heatmap.
  color         String      @default("#6366f1")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  blockTypes    BlockType[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Categories are per-user: two users may each own a "Study" category, so the
  // derived key is unique within an owner rather than globally.
  @@unique([userId, key])
  @@index([userId])
}

model BlockType {
  id             String           @id @default(cuid())
  userId         String
  categoryId     String
  name            String
  durationMinutes Int
  description     String?
  // Soft delete. A block type referenced by any past completion or weekly
  // target can't be hard-deleted (onDelete: Restrict below), and doing so would
  // erase the points/emblems those completions earned. Instead, "deleting"
  // stamps archivedAt: the row is hidden from every list, planner, and
  // quick-complete, but its history stays intact. null = active.
  archivedAt      DateTime?
  weeklyPlanItems WeeklyPlanItem[]
  blockInstances BlockInstance[]
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([userId, archivedAt])
  @@unique([userId, name])
}

model WeeklyPlan {
  id          String           @id @default(cuid())
  userId      String
  weekStart   DateTime
  weekEnd     DateTime
  planItems   WeeklyPlanItem[]
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
  @@unique([userId, weekStart])
}

model WeeklyPlanItem {
  id           String      @id @default(cuid())
  weeklyPlanId String
  blockTypeId  String
  targetCount  Int
  weeklyPlan   WeeklyPlan  @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  blockType    BlockType   @relation(fields: [blockTypeId], references: [id], onDelete: Restrict)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([weeklyPlanId])
  @@index([blockTypeId])
  @@unique([weeklyPlanId, blockTypeId])
}

model BlockInstance {
  id          String    @id @default(cuid())
  userId      String
  blockTypeId String
  completedAt DateTime
  scheduledAt DateTime?
  notes       String?
  // Points earned by this completion, computed once at completion time from the
  // block's duration and its category weight, then frozen. Editing the category
  // weight later never re-scores past completions. See progress/points-calculator.ts.
  points      Int       @default(0)
  // Google Calendar sync (#35). One-way, best-effort, completion-only.
  //   NOT_APPLICABLE — the owner has no calendar-connected Google account.
  //   SYNCED         — an event was created; `googleEventId` holds its id.
  //   PENDING        — the write was attempted but failed; awaits retry (#36).
  // The completion itself never depends on this: it is persisted first and the
  // sync is a follow-on that can only downgrade the status, never fail the row.
  calendarSyncStatus CalendarSyncStatus @default(NOT_APPLICABLE)
  googleEventId      String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  blockType   BlockType @relation(fields: [blockTypeId], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([blockTypeId])
  @@index([completedAt])
  // #36 retries scan for PENDING rows; keep that lookup cheap.
  @@index([calendarSyncStatus])
}

enum CalendarSyncStatus {
  NOT_APPLICABLE
  SYNCED
  PENDING
}
