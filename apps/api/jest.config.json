{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "roots": ["<rootDir>/src"],
  "testRegex": "\\.spec\\.ts$",
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "isolatedModules": true,
        "tsconfig": {
          "esModuleInterop": true,
          "experimentalDecorators": true,
          "emitDecoratorMetadata": true
        }
      }
    ]
  },
  "testEnvironment": "node"
}
