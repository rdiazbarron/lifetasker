{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": ".e2e-spec\\.ts$",
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "isolatedModules": true,
        "tsconfig": {
          "esModuleInterop": true,
          "experimentalDecorators": true,
          "emitDecoratorMetadata": true
        }
      }
    ]
  },
  "testEnvironment": "node",
  "testTimeout": 30000
}
