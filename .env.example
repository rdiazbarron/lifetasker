# Shared by the API and the web app's Better Auth instance — they use the same
# database so authentication maps onto the same User identity.
DATABASE_URL="postgresql://lifetasker:lifetasker@localhost:5433/lifetasker?schema=public"

# Comma-separated origins allowed to call the API with credentials (cookies).
CORS_ORIGINS="http://localhost:3000"

# --- Authentication (web app: apps/web/.env.local) ---
# Secret used by Better Auth to sign sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET="replace-me-with-a-random-32-byte-secret"

# Public base URL of the web app (where the /api/auth/* routes are served).
BETTER_AUTH_URL="http://localhost:3000"

# Base URL of the NestJS API, consumed by the browser fetch client.
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# --- Google Calendar integration — #33/#34/#35 ---
# Needed by BOTH apps and they share the SAME OAuth client:
#   - web (apps/web/.env.local): powers "Sign in with Google" / "Connect".
#   - api (apps/api/.env):       refreshes the stored token and writes events
#                                to the "LifeTasker" calendar on completion.
# OAuth client powering "Sign in with Google" and calendar sync.
# One-time setup in Google Cloud Console:
#   1. Enable the "Google Calendar API".
#   2. Create an OAuth 2.0 Client ID of type "Web application".
#   3. Add this Authorized redirect URI (matches BETTER_AUTH_URL):
#        http://localhost:3000/api/auth/callback/google
#   4. Calendar is a "sensitive" scope, so keep the OAuth consent screen in
#      "Testing" mode and add each user under "Test users" — no Google
#      verification is needed for personal use.
# Leave these unset to disable Google entirely; the app then runs on
# email/password exactly as before.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Set to "true" only once the two values above are configured. This toggles the
# Google connect/sign-in buttons in the UI (they stay hidden otherwise).
NEXT_PUBLIC_GOOGLE_ENABLED="false"
