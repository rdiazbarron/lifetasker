# Shared by the API and the web app's Better Auth instance — they use the same
# database so authentication maps onto the same User identity.
DATABASE_URL="postgresql://lifetasker:lifetasker@localhost:5433/lifetasker?schema=public"

# Comma-separated origins allowed to call the API with credentials (cookies).
CORS_ORIGINS="http://localhost:3000"

# --- Authentication (web app: apps/web/.env.local) ---
# Secret used by Better Auth to sign sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET="replace-me-with-a-random-32-byte-secret"

# Public base URL of the web app (where the /api/auth/* routes are served).
BETTER_AUTH_URL="http://localhost:3000"

# Base URL of the NestJS API, consumed by the browser fetch client.
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
